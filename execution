# === SPEECH VAD SETTINGS ===
def record_audio_wait_start():
    recorded_frames = []
    triggered = False
    silent_frame_count = 0
    speech_start_time = None
    user_started_speaking = False
    done_event = threading.Event()

    # === VAD CONFIGURATION ===
    VAD_MODE = 0  # use 0 for very sensitive, 3 for very strict
    SAMPLE_RATE = 48000
    FRAME_DURATION = 30  # ms
    FRAME_SIZE = int(SAMPLE_RATE * FRAME_DURATION / 1000)
    SILENCE_DURATION_MS = 2000
    SILENCE_FRAME_THRESHOLD = SILENCE_DURATION_MS // FRAME_DURATION
    MAX_SPEECH_DURATION_SEC = 50
    IGNORE_FIRST_N_SECONDS = 1 # ignore Pepper's speech
    SPEECH_CONFIRM_FRAMES = 5  # must detect 5 consecutive speech frames before triggering
    AUDIO_FILE = "recording.wav"

    vad = webrtcvad.Vad()
    vad.set_mode(VAD_MODE)

    start_time = None
    pre_speech_buffer = []
    speech_frame_count = 0

    def record_callback(indata, frames, time_info, status):
        nonlocal user_started_speaking, triggered, recorded_frames
        nonlocal silent_frame_count, speech_start_time, start_time, speech_frame_count

        if start_time is None:
            start_time = time.time()

        if status:
            log(f"Status: {status}", "Audio")

        current_time = time.time()
        audio_bytes = indata[:, 0].tobytes()

        if current_time - start_time < IGNORE_FIRST_N_SECONDS:
            return  # Skip frames during initial ignore window

        is_speech = vad.is_speech(audio_bytes, SAMPLE_RATE)

        if not user_started_speaking:
            if is_speech:
                speech_frame_count += 1
                pre_speech_buffer.append(audio_bytes)
                if speech_frame_count >= SPEECH_CONFIRM_FRAMES:
                    log("🟢 Confirmed speech start - beginning recording", "Audio")
                    user_started_speaking = True
                    triggered = True
                    speech_start_time = time.time()
                    recorded_frames.extend(pre_speech_buffer)
                    silent_frame_count = 0
            else:
                speech_frame_count = 0
                pre_speech_buffer.clear()
        elif triggered:
            recorded_frames.append(audio_bytes)

            if is_speech:
                silent_frame_count = 0
            else:
                silent_frame_count += 1

            duration = time.time() - speech_start_time
            if duration > MAX_SPEECH_DURATION_SEC:
                log("⏱️ Max speech duration reached (30s)", "Audio")
                done_event.set()
                raise sd.CallbackStop()

            # if silent_frame_count > SILENCE_FRAME_THRESHOLD:
            #     log(f"🔴 {SILENCE_DURATION_MS / 1000:.1f}s silence detected. Stopping...", "Audio")
            #     done_event.set()
            #     raise sd.CallbackStop()

            # When silence detected, extend recording a bit before stopping
            if silent_frame_count > SILENCE_FRAME_THRESHOLD:
                log(f"🟠 Silence detected. Recording an extra second...", "Audio")
                time.sleep(1.0)  # buffer time
                done_event.set()
                raise sd.CallbackStop()

    log("🎙️ Listening for user's first word (robust filtering)...", "Audio")
    try:

        #info = sd.query_devices(DEVICE_INDEX)
        #log(f"ℹ️ Using device {DEVICE_INDEX}: {info['name']} (Max channels: {info['max_input_channels']})", "Audio")

        #sd.default.device = (DEVICE_INDEX, None)  # Set input device for sounddevice (input only)

        with sd.InputStream(
            channels=CHANNELS,
            samplerate=SAMPLE_RATE,
            blocksize=FRAME_SIZE,
            dtype='int16',
            device=DEVICE_INDEX,
            callback=record_callback
        ):
            done_event.wait(timeout=MAX_SPEECH_DURATION_SEC + 10)
    except Exception as e:
        log(f"⚠️ Recording error: {e}", "Audio")

    if recorded_frames:
        with wave.open(AUDIO_FILE, 'wb') as wf:
            wf.setnchannels(CHANNELS)
            wf.setsampwidth(2)
            wf.setframerate(SAMPLE_RATE)
            wf.writeframes(b''.join(recorded_frames))
        log(f"✅ Audio saved to {AUDIO_FILE}", "Audio")
    else:
        log("⚠️ No speech detected. Nothing saved.", "Audio")


# === REAL-TIME VAD + TRANSCRIPTION ===
def listen_and_transcribe():
    recorded_frames = []
    triggered = False
    silent_frame_count = 0
    speech_start_time = None
    user_started_speaking = False
    done_event = threading.Event()

    VAD_MODE = 3  # 0 = very sensitive, 3 = strict
    SAMPLE_RATE = 16000  # Whisper works best at 16 kHz
    FRAME_DURATION = 30  # ms
    FRAME_SIZE = int(SAMPLE_RATE * FRAME_DURATION / 1000)
    SILENCE_DURATION_MS = 2000
    SILENCE_FRAME_THRESHOLD = SILENCE_DURATION_MS // FRAME_DURATION
    SPEECH_CONFIRM_FRAMES = 5

    vad = webrtcvad.Vad()
    vad.set_mode(VAD_MODE)

    start_time = None
    pre_speech_buffer = []
    speech_frame_count = 0

    def record_callback(indata, frames, time_info, status):
        nonlocal user_started_speaking, triggered, recorded_frames
        nonlocal silent_frame_count, speech_start_time, start_time, speech_frame_count

        if start_time is None:
            start_time = time.time()

        if status:
            log(f"Status: {status}", "Audio")

        audio_bytes = indata[:, 0].tobytes()
        is_speech = vad.is_speech(audio_bytes, SAMPLE_RATE)

        if not user_started_speaking:
            if is_speech:
                speech_frame_count += 1
                pre_speech_buffer.append(audio_bytes)
                if speech_frame_count >= SPEECH_CONFIRM_FRAMES:
                    log("🟢 Speech detected — starting utterance capture", "VAD")
                    user_started_speaking = True
                    triggered = True
                    speech_start_time = time.time()
                    recorded_frames.extend(pre_speech_buffer)
                    silent_frame_count = 0
            else:
                speech_frame_count = 0
                pre_speech_buffer.clear()
        elif triggered:
            recorded_frames.append(audio_bytes)
            if is_speech:
                silent_frame_count = 0
            else:
                silent_frame_count += 1
                if silent_frame_count > SILENCE_FRAME_THRESHOLD:
                    log("🛑 Silence detected — stopping utterance", "VAD")
                    done_event.set()
                    raise sd.CallbackStop()

    log("🎙️ Listening for speech...", "Audio")
    try:
        with sd.InputStream(
            channels=1,
            samplerate=SAMPLE_RATE,
            blocksize=FRAME_SIZE,
            dtype='int16',
            device=DEVICE_INDEX,
            callback=record_callback
        ):
            done_event.wait()
    except Exception as e:
        log(f"⚠️ Recording error: {e}", "Audio")

    if not recorded_frames:
        log("⚠️ No speech detected", "VAD")
        return ""

    # Save entire utterance to WAV
    with wave.open(AUDIO_FILE, 'wb') as wf:
        wf.setnchannels(1)
        wf.setsampwidth(2)
        wf.setframerate(SAMPLE_RATE)
        wf.writeframes(b''.join(recorded_frames))

    log(f"✅ Utterance saved ({len(recorded_frames)} frames)", "Audio")
    result = model.transcribe(AUDIO_FILE)
    transcript = result["text"].strip()
    log(f"📝 Transcript: {transcript}", "Whisper")
    return transcript



