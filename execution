# === CLASSIFY SENTIMENT ===
def classify_sentiment(transcript):
    lowered = transcript.lower()
    keywords_negative = ["no", "not really", "i don't", "i did not", "i didn't"]
    keywords_positive = ["yes", "i did", "yeah", "good", "sure", "okay", "fine"]
    for kw in keywords_negative:
        if kw in lowered:
            log(f"Keyword match: '{kw}' → negative", "LLM")
            return "negative"
    for kw in keywords_positive:
        if kw in lowered:
            log(f"Keyword match: '{kw}' → positive", "LLM")
            return "positive"
    return classify_sentiment_llm(transcript)

def classify_sentiment_llm(transcript):
    log("Classifying with LLM...", "LLM")
    prompt = (
        "You are a sentiment classifier. Only respond with one of: 'positive', 'negative', or 'unclear'.\n"
        "Examples:\n"
        "Input: Yes\nSentiment: positive\n"
        "Input: No\nSentiment: negative\n"
        "Input: Not really.\nSentiment: negative\n"
        "Input: I don’t know.\nSentiment: unclear\n"
        f"Input: {transcript}\nSentiment:"
    )
    payload = {
        "model": MODEL_NAME,
        "prompt": prompt,
        "stream": False,
        "options": {"num_predict": 10}
    }
    try:
        response = requests.post(OLLAMA_ENDPOINT, json=payload)
        if response.status_code == 200:
            sentiment_raw = response.json().get("response", "").strip().lower()
            for s in ["positive", "negative", "unclear"]:
                if s in sentiment_raw:
                    log(f"LLM classified as: {s}", "LLM")
                    return s
            log(f"Unrecognized LLM response: {sentiment_raw}", "LLM")
        else:
            log(f"LLM error: {response.text}", "LLM")
    except Exception as e:
        log(f"LLM request failed: {e}", "LLM")
    return "unclear"

# === GENERATE REPLY ===
def generate_contextual_reply(transcript, base_response):
    log("Generating contextual reply with LLM...", "LLM")

    prompt = (
        "You are Sava, a polite humanoid robot in a conversation with the Dean of Humanities.\n\n"
        f'The Dean just said: "{transcript}"\n\n'
        f'Default reply: "{base_response}"\n\n'
        "Task: Rewrite slightly to be warm and natural, 3 sentences, no questions, no names.\n"
        "Return only the sentences to speak."
    )

    payload = {
        "model": MODEL_NAME,
        "prompt": prompt,
        "stream": False,
        "options": {"num_predict": 100}
    }
    try:
        response = requests.post(OLLAMA_ENDPOINT, json=payload)
        if response.status_code == 200:
            reply = response.json().get("response", "").strip()
            log(f"LLM contextual reply: {reply}", "LLM")
            return reply
    except Exception as e:
        log(f"LLM reply error: {e}", "LLM")
    return base_response

def speak_with_pepper(text, rate=90):

    log(f"Raw LLM output: {text}", "Pepper")
    # Clean text
    cleaned = text.strip().replace("\n", " ").replace('"', "'")

    log(f"Speaking: {cleaned}", "Pepper")

    # Split into sentences
    sentences = re.split(r'(?<=[.!?]) +', cleaned)

    # Set speech rate
    set_speed = f'ssh {ssh_options} -i {key_path} nao@{PEPPER_IP} "/opt/aldebaran/bin/qicli call ALTextToSpeech.setParameter speed {rate}"'
    subprocess.run(set_speed, shell=True)

    # Speak each sentence with a small pause
    for sentence in sentences:
        safe_text = sentence.replace('"', r'\"')
        animated_cmd = f'ssh {ssh_options} -i {key_path} nao@{PEPPER_IP} "/opt/aldebaran/bin/qicli call ALAnimatedSpeech.say \\\"{safe_text}\\\""'
        subprocess.run(animated_cmd, shell=True)





